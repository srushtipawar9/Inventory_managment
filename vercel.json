{
  "installCommand": "pip install -r requirements.txt && python manage.py collectstatic --noinput",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index"
    }
  ],
  "functions": {
    "api/index.py": {
      "maxDuration": 60,
      "memory": 3008
    }
  },
  "env": {
    "VERCEL": "1",
    "DJANGO_SETTINGS_MODULE": "core.settings"
  }
}
